{
  "name": "wfm-api",
  "type": "commonjs",
  "version": "0.0.0",
  "packageManager": "pnpm@11.15.1",
  "description": "TypeScript API wrapper for Warframe Market (community, unofficial)",
  "license": "MIT",
  "homepage": "https://github.com/CloudeaSoft/wfm-api",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CloudeaSoft/wfm-api.git"
  },
  "bugs": {
    "url": "https://github.com/CloudeaSoft/wfm-api/issues"
  },
  "keywords": [
    "warframe",
    "warframe.market",
    "wfm",
    "api"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib"
  ],
  "engines": {
    "node": ">=18",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "tsc --build --force",
    "dtsc": "tsc --build --force",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^10.7.0",
    "jiti": "^2.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "4.1.10"
  }
}
