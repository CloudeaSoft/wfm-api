{
  "compilerOptions": {
    "incremental": true,
    "composite": true,
    "target": "esnext",
    "rootDir": "src",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "outDir": "lib",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
